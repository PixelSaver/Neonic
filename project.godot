; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Neonic"
run/main_scene="uid://dx1ta1v0qbj8m"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.05882353, 0.05882353, 0.05882353, 1)
boot_splash/show_image=false
config/icon="res://assets/icon.svg"

[autoload]

PhantomCameraManager="*uid://duq6jhf6unyis"
Global="*res://scripts/global.gd"
EnemyDatabase="*uid://caqcwylnj8cbm"
PlayerSettings="*uid://bowcdsuyi2whd"

[display]

window/size/viewport_width=1720
window/size/viewport_height=972
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/Todo_Manager/plugin.cfg", "res://addons/godot_super-wakatime/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/resources/": "blue",
"res://scenes/ui/": "green",
"res://scripts/": "orange",
"res://scripts/upgrades/": "yellow"
}

